              { "id": "service-order-bottom", "nodeId": "service-order", "templateId": "bottom", "label": "下方端口", "offset": { "x": 60, "y": 112 } },
              { "id": "service-order-left", "nodeId": "service-order", "templateId": "left", "label": "左侧端口", "offset": { "x": 0, "y": 56 } }
