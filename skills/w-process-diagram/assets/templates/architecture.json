      "props": { "route": { "type": "orthogonal" } }
    },
    {
      "id": "edge-gateway-order",
      "source": { "nodeId": "service-gateway", "portId": "service-gateway-right" },
      "target": { "nodeId": "service-order", "portId": "service-order-left" },
      "label": "路由",
      "props": { "route": { "type": "orthogonal" } }
    },
    {
      "id": "edge-order-data",
      "source": { "nodeId": "service-order", "portId": "service-order-bottom" },
      "target": { "nodeId": "data-orders", "portId": "data-orders-top" },
      "label": "读写",
      "props": { "route": { "type": "orthogonal" } }
    }
  ],
  "viewport": { "x": 0, "y": 0, "zoom": 1 }
