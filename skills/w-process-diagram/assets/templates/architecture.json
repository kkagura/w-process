            "ports": [
              { "id": "service-web-top", "nodeId": "service-web", "templateId": "top", "label": "上方端口", "offset": { "x": 60, "y": 0 } },
              { "id": "service-web-right", "nodeId": "service-web", "templateId": "right", "label": "右侧端口", "offset": { "x": 120, "y": 56 } },
              { "id": "service-web-bottom", "nodeId": "service-web", "templateId": "bottom", "label": "下方端口", "offset": { "x": 60, "y": 112 } },
              { "id": "service-web-left", "nodeId": "service-web", "templateId": "left", "label": "左侧端口", "offset": { "x": 0, "y": 56 } }
            ],
            "props": {}
          }
        ]
      },
      {
        "id": "layer-service",
        "type": "layer",
        "label": "服务层",
