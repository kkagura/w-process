            "props": {}
          }
        ]
      },
      {
        "id": "layer-data",
        "type": "layer",
        "label": "数据层",
        "position": { "x": 20, "y": 580 },
        "size": { "width": 840, "height": 220 },
        "props": {},
        "children": [
          {
            "id": "data-orders",
            "type": "data",
