                  { "id": "task-submit-order-right", "nodeId": "task-submit-order", "templateId": "right", "label": "右侧端口", "offset": { "x": 160, "y": 36 } }
                ],
                "props": {}
              }
            ]
          },
          {
            "id": "lane-system",
            "type": "lane",
            "label": "订单系统",
            "position": { "x": 20, "y": 216 },
            "size": { "width": 1020, "height": 160 },
            "props": { "orientation": "horizontal", "labelSize": 96 },
            "children": [
              {
                "id": "decision-stock",
                "type": "decision",
                "label": "库存充足？",
                "position": { "x": 580, "y": 248 },
                "size": { "width": 144, "height": 96 },
