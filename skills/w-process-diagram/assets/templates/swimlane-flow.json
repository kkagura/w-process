                  { "id": "decision-stock-bottom", "nodeId": "decision-stock", "templateId": "bottom", "label": "下方端口", "offset": { "x": 72, "y": 96 } },
                  { "id": "decision-stock-left", "nodeId": "decision-stock", "templateId": "left", "label": "否 / 左侧端口", "offset": { "x": 0, "y": 48 } }
