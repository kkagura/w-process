{
  "name": "@w-process/flow-node-renderer",
  "version": "0.0.2",
  "description": "Node.js API and CLI for rendering w-process scene JSON documents to PNG",
  "type": "module",
  "files": [
    "dist"
  ],
  "bin": {
    "w-process-render": "./dist/cli.mjs"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=22.18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kkagura/w-process.git",
    "directory": "packages/flow-node-renderer"
  },
  "homepage": "https://github.com/kkagura/w-process#readme",
  "bugs": {
    "url": "https://github.com/kkagura/w-process/issues"
  },
  "keywords": [
    "w-process",
    "flowchart",
    "canvas",
    "diagram",
    "png",
    "cli"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "pnpm run typecheck && tsdown",
    "dev": "tsdown --watch",
    "prepack": "pnpm run build",
    "render": "node dist/cli.mjs",
    "test": "pnpm --filter @w-process/flow-core run build && pnpm run build && node --test test/render.test.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo-google-fonts/noto-sans-sc": "^0.4.3",
    "@napi-rs/canvas": "^1.0.2",
    "@w-process/flow-core": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^24.12.3",
    "tsdown": "^0.22.13",
    "typescript": "~6.0.2",
    "unrun": "^0.3.1"
  }
}
