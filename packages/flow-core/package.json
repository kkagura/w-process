{
  "name": "@w-process/flow-core",
  "version": "0.0.1",
  "description": "Framework-agnostic scene, layout, routing, and Canvas rendering core for w-process",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kkagura/w-process.git",
    "directory": "packages/flow-core"
  },
  "homepage": "https://github.com/kkagura/w-process#readme",
  "bugs": {
    "url": "https://github.com/kkagura/w-process/issues"
  },
  "keywords": [
    "w-process",
    "flowchart",
    "canvas",
    "diagram",
    "typescript"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "pnpm run typecheck && tsdown",
    "dev": "tsdown --watch",
    "prepack": "pnpm run build",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsdown": "^0.22.13",
    "typescript": "~6.0.2",
    "unrun": "^0.3.1"
  }
}
